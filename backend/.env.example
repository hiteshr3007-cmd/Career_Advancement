# --- App ---
ENVIRONMENT=development
# JWT signing secret. Generate your own — NEVER commit a real one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-64-hex-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
# Default: your own local Docker Postgres (solo/offline dev only — see README
# "Running your own isolated local Postgres instead"). Used when running the
# API directly (uvicorn/venv), and as the fallback for `docker compose up` if
# DOCKER_DATABASE_URL below isn't set.
DATABASE_URL=postgresql+psycopg2://platform:platform@localhost:5433/career_platform

# --- Shared team database (Neon) ---
# This project's team database is Neon (pgvector-enabled, serverless Postgres).
# Get the real connection string from whoever administers the Neon project via
# a secure channel — NEVER commit it here or paste it in a public channel.
# See README "Neon: our shared team database" for full instructions. Once you
# have it, set BOTH of these to the same value (uncomment DATABASE_URL's Neon
# line below and comment out/replace the local one above, or just overwrite it):
#   DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>/<db>?sslmode=require
# DOCKER_DATABASE_URL is only read when running via `docker compose` (see
# docker-compose.yml) — use the same connection string:
# DOCKER_DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>/<db>?sslmode=require
#
# Prefer the "Pooled connection" string from the Neon dashboard (host contains
# "-pooler") once more than 1-2 people are using it concurrently — app/database.py
# auto-detects "-pooler" in the URL and switches to NullPool automatically, no
# other config needed. Only one person should run `alembic upgrade head`
# against the shared DB after pulling a new migration.

# Connection pool sizing (BK-1). Raise if you expect higher concurrency.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=10

# --- Roles ---
# Comma-separated emails that become administrators automatically on registration.
# Everyone else registers as a candidate; recruiters/HR reviewers/employers are
# created by an admin via POST /api/v1/admin/users. Keep this list short.
ADMIN_EMAILS=admin@yourcompany.com

# Comma-separated emails that become super admins on registration. A super
# admin's sole job is CRUD over administrator/super_admin accounts (via
# /api/v1/super-admin/admins) — they cannot manage candidates/staff or view
# candidate data. Takes precedence over ADMIN_EMAILS. Bootstrap without an
# allowlist using: python scripts/provision_super_admin.py <email> <password>
SUPER_ADMIN_EMAILS=superadmin@yourcompany.com

# --- AWS S3 (unused for now — resumes are stored in Postgres, see app/services/storage.py) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=career-platform-resumes

# --- OpenAI (unused for now — resume-parsing LLM fallback and embeddings are
# local/free, see app/services/resume_parsing/llm_parser.py and
# app/services/matching/embeddings.py) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# --- Phase 3 career-plan LLM (optional; local Ollama by default) ---
# Career plans work without any of this (deterministic output, llm_used=false).
# To enrich narratives/roadmap with a local LLM, run Ollama and set these.
# Structured output uses schema-constrained decoding, so a small model is fine.
# NOTE: the code default model is llama3.1:8b, which is slow on modest hardware —
# a small model such as qwen2.5:3b completes a plan in ~40-110s. FALLBACK_MODEL is
# tried only if the primary's constrained output won't conform; blank to disable.
# PHASE3_LLM_ENABLED=true
# PHASE3_LLM_PROVIDER=ollama
# PHASE3_LLM_BASE_URL=http://localhost:11434/v1
# PHASE3_LLM_MODEL=qwen2.5:3b
# PHASE3_LLM_FALLBACK_MODEL=qwen2.5:7b
# PHASE3_LLM_TIMEOUT=60

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend base URL (used to build links embedded in emails, e.g. the
# password-reset link: {FRONTEND_BASE_URL}/reset-password?token=...) ---
FRONTEND_BASE_URL=http://localhost:3000

# --- SMTP (optional — password-reset emails are logged instead of sent when
# SMTP_HOST is unset, so local dev works without a real mail provider; see
# app/services/email.py). Any standard SMTP server works — Gmail, SES SMTP
# endpoint, SendGrid SMTP relay, Mailtrap for dev/testing, etc. ---
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_FROM_EMAIL=no-reply@yourcompany.com
